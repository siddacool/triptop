{
  "name": "triptop",
  "version": "4.12.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "svelte-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "check": "npm run svelte-check && eslint . && npm run lint",
    "check:fix": "npm run svelte-check && eslint . && npm run format",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/sveltekit": "10.4.4",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-a11y": "10.4.4",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^24",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "10.4.4",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "sass-embedded": "^1.100.0",
    "storybook": "10.4.4",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@flightlesslabs/currency": "^0.2.1",
    "@flightlesslabs/dodo-ui": "^0.36.8",
    "@flightlesslabs/dodo-ui-bits": "^0.10.10",
    "@flightlesslabs/dodo-ui-date": "^0.4.31",
    "@flightlesslabs/dodo-ui-numeric": "^0.2.30",
    "@flightlesslabs/time-utils": "^0.2.2",
    "@iconify/svelte": "^5.2.1",
    "@internationalized/date": "^3.12.2",
    "bits-ui": "^2.18.1",
    "dexie": "^4.4.3",
    "nanoid": "^5.1.11",
    "svelte-number-format": "^2.0.0"
  }
}
