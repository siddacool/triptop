{
  "name": "triptop",
  "version": "5.22.3",
  "type": "module",
  "description": "Simple, offline travel budgeting app",
  "homepage": "https://triptop.siddheshmangela.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/siddacool/triptop.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "svelte-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "check": "pnpm run svelte-check && eslint . && pnpm run lint",
    "check:fix": "pnpm run svelte-check && eslint . && pnpm run format",
    "test:unit": "vitest",
    "test": "pnpm run test:unit --run",
    "storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/sveltekit": "10.5.2",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "10.5.2",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "sass-embedded": "^1.100.0",
    "storybook": "10.5.2",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@flightlesslabs/currency": "^0.2.1",
    "@flightlesslabs/dodo-ui": "^0.36.13",
    "@flightlesslabs/dodo-ui-bits": "^0.11.6",
    "@flightlesslabs/dodo-ui-date": "^0.4.37",
    "@flightlesslabs/dodo-ui-numeric": "^0.2.35",
    "@iconify/svelte": "^5.2.2",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "bits-ui": "^2.18.1",
    "dayjs": "^1.11.21",
    "dexie": "^4.4.4",
    "nanoid": "^6.0.0",
    "svelte-number-format": "^2.0.0"
  }
}
